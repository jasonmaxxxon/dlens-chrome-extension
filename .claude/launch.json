{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wxt-dev",
      "runtimeExecutable": "/opt/homebrew/bin/npx",
      "runtimeArgs": ["wxt"],
      "port": 3000
    },
    {
      "name": "belt-concept",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "require('http').createServer((q,r)=>{const f=require('path').join(process.cwd(),q.url==='/'?'belt-buckle-3d-preview.html':q.url.slice(1));require('fs').readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{r.writeHead(200,{'Content-Type':'text/html'});r.end(d)}})}).listen(8080,()=>console.log('http://localhost:8080'))"],
      "port": 8080
    }
  ]
}
