{
  "name": "dlens-chrome-extension-v0",
  "version": "0.3.12",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "node scripts/build-extension.mjs",
    "build:pr": "node scripts/build-extension.mjs --variant pr-only",
    "build:wxt": "wxt build",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "storage:seam-guard": "node scripts/check-no-raw-storage.mjs",
    "boundary:guard:view": "node scripts/check-view-boundary.mjs",
    "boundary:guard:vm": "node scripts/check-viewmodel-boundary.mjs",
    "boundary:guard": "npm run boundary:guard:view && npm run boundary:guard:vm",
    "storage:migrate-fixtures": "node scripts/check-migration-fixtures.mjs",
    "qa:harness:fixture": "node scripts/qa-live-pipeline-harness.mjs --trace docs/qa/assets/2026-06-13/full-live-backend-llm/live-trace-full-hover-save-queue-analysis.json --label full-hover-save-queue-analysis-backend-llm --skip-build --require-phases hover.detected,preview.confirmed,signal.saved,backend.request,crawl.queued,capture.ready,llm.call,analysis.ready,ui.ready --terminal ui.ready",
    "backend:locate": "node scripts/locate-ingest-core.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.469.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.330",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@wxt-dev/module-react": "1.1.1",
    "jsdom": "^29.1.1",
    "rollup": "npm:@rollup/wasm-node@4.60.2",
    "typescript": "^5.8.3",
    "wxt": "0.20.7"
  },
  "overrides": {
    "vite": "5.4.19"
  }
}
